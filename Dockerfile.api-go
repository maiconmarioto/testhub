FROM golang:1.25-alpine AS build

WORKDIR /src
COPY apps/api-go/go.mod apps/api-go/go.sum* ./
RUN go mod download
COPY apps/api-go ./
RUN go build -o /out/testhub-api-go ./cmd/api

FROM alpine:3.22

WORKDIR /app
COPY --from=build /out/testhub-api-go /usr/local/bin/testhub-api-go
RUN mkdir -p /app/.testhub-data/suites /app/.testhub-data/runs

CMD ["testhub-api-go"]
