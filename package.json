{
  "name": "testhub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "testhub": "./dist/cli.js",
    "testhub-mcp": "./dist/mcp.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "server": "tsx src/server.ts",
    "worker": "tsx src/worker.ts",
    "mcp": "tsx src/mcp.ts",
    "migrate": "tsx src/db/migrate.ts",
    "web": "next dev apps/web -p 3000",
    "web:build": "next build apps/web",
    "test": "vitest run",
    "validate": "tsx src/cli.ts validate",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test:api": "tsx src/cli.ts run examples/api-health.yaml --base-url https://httpbin.org --report-dir .testhub-runs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@modelcontextprotocol/sdk": "^1.22.0",
    "@playwright/test": "^1.53.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "ajv": "^8.17.1",
    "bullmq": "^5.76.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^12.1.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.11.0",
    "next": "^16.2.4",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "postcss": "^8.5.12"
  }
}
